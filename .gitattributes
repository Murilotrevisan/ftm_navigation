# Normalise to LF in the repository. The build/test container is Linux; shell
# scripts and Dockerfiles with CRLF fail there with confusing errors.
* text=auto eol=lf

# Scripts that MUST be LF regardless of platform
*.sh        text eol=lf
*.bash      text eol=lf
Dockerfile  text eol=lf
*.mk        text eol=lf
Makefile    text eol=lf

# Windows-only helpers keep CRLF
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Binary
*.png       binary
*.bin       binary
*.elf       binary
